// JAMALI MD - AI Commands (OpenAI, GPT, Copilot, DeepSeek, Advanced)

const { cmd } = require('../momy');
const axios = require('axios');

cmd({
    pattern: "openai",
    alias: ["chatgpt", "jamalai", "open-gpt"],
    desc: "Chat with OpenAI",
    category: "ai",
    react: "🧠",
    filename: __filename
}, async (conn, mek, m, { from, reply, args, myquoted }) => {
    try {
        const text = args.join(" ");
        
        if (!text) {
            return reply("🤖 *JAMALI MD - OpenAI*\n\nUsage: .openai your message\nExample: .openai Hello, how are you?\n\n> 🔥 Powered by JAMALI TECH TZ");
        }

        await reply("⏳ Asking OpenAI...");

        const apiUrl = `https://vapis.my.id/api/openai?q=${encodeURIComponent(text)}`;
        const { data } = await axios.get(apiUrl);

        if (!data || !data.result) {
            await m.react("❌");
            return reply("❌ OpenAI failed to respond\n\n> 🔥 Powered by JAMALI TECH TZ");
        }

        await conn.sendMessage(from, {
            text: data.result + "\n\n> 🔥 Powered by JAMALI TECH TZ"
        }, { quoted: myquoted });

        await m.react("✅");

    } catch (e) {
        console.error("Error in OpenAI command:", e);
        await m.react("❌");
        reply("❌ An error occurred with OpenAI\n\n> 🔥 Powered by JAMALI TECH TZ");
    }
});

