┃ 👑 Owner: ${channelMeta.owner || 'Unknown'}
┃ 📅 Created: ${channelMeta.creation || 'Unknown'}
┃ 🔗 Link: ${q}
┗━━━━━━━━━━━━━━━━━━━━━━━━`,
            contextInfo: getContextInfo({ sender: sender })
        }, { quoted: fakevCard });
        
    } catch (e) {
        await conn.sendMessage(from, {
            text: `❌ Failed to fetch channel info\n\nError: ${e.message}`,
            contextInfo: getContextInfo({ sender: sender })
        }, { quoted: fakevCard });
        l(e);
    }
});
});
