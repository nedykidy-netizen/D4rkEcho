try{
    if (!isOwner) {
        return await conn.sendMessage(from, {
            text: `❌ This command is only for bot owner`,
            contextInfo: getContextInfo({ sender: sender })
        }, { quoted: fakevCard });
    }
    
    if (!q) {
        return await conn.sendMessage(from, {
            text: `❌ Please provide a channel link\n\nExample: ${prefix}channelinfo https://whatsapp.com/channel/1234567890`,
